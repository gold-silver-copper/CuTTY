<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
   <Package Name="CuTTY" UpgradeCode="87c21c74-dbd5-4584-89d5-46d9cd0c40a7" Language="1033" Codepage="1252" Version="0.18.4" Manufacturer="CuTTY" InstallerVersion="200">
      <MajorUpgrade AllowSameVersionUpgrades="yes" DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
      <Icon Id="CuTTYIco" SourceFile=".\cutty\windows\cutty.ico" />
      <WixVariable Id="WixUILicenseRtf" Value=".\cutty\windows\wix\license.rtf" />
      <Property Id="ARPPRODUCTICON" Value="CuTTYIco" />
      <MediaTemplate EmbedCab="yes" />
      <ui:WixUI Id="WixUI_Minimal" />
      <Feature Id="ProductFeature" Title="ConsoleApp" Level="1">
         <ComponentRef Id="CuTTYExe" />
         <ComponentRef Id="CuTTYShortcut" />
         <ComponentRef Id="ModifyPathEnv" />
         <ComponentRef Id="ContextMenu" />
      </Feature>
      <!-- Application binaries -->
      <DirectoryRef Id="CuTTYProgramFiles">
         <Component Id="CuTTYExe">
            <File Id="CuTTYExeFile" Source=".\target\release\cutty.exe" Name="cutty.exe" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="CuTTYProgramMenu">
         <!-- Application shortcut -->
         <Component Id="CuTTYShortcut" Guid="aa36e61a-23cd-4383-b744-2f78e912f0dc">
            <Shortcut Id="CuTTYShortcutFile" Name="CuTTY" Description="A cross-platform, GPU-accelerated terminal emulator" Target="[CuTTYProgramFiles]cutty.exe" />
            <RemoveFolder Id="CuTTYProgramMenu" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Microsoft\CuTTY" Name="installed" Type="integer" Value="1" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="CuTTYProgramFiles">
         <!-- Add to PATH -->
         <Component Id="ModifyPathEnv" Guid="edf0b679-9eb6-46f7-a5d1-5160f30acb34" KeyPath="yes">
            <Environment Id="PathEnv" Value="[CuTTYProgramFiles]" Name="PATH" Permanent="no" Part="first" Action="set" System="yes" />
         </Component>
      </DirectoryRef>
      <StandardDirectory Id="ProgramFiles64Folder">
         <Directory Id="CuTTYProgramFiles" Name="CuTTY" />
      </StandardDirectory>
      <StandardDirectory Id="ProgramMenuFolder">
         <Directory Id="CuTTYProgramMenu" Name="CuTTY" />
      </StandardDirectory>
      <!-- Add context menu -->
      <Component Id="ContextMenu" Guid="449f9121-f7b9-41fe-82da-52349ea8ff91" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open CuTTY here\command">
            <RegistryValue Type="string" Value='[CuTTYProgramFiles]cutty.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open CuTTY here">
            <RegistryValue Type="string" Name="Icon" Value="[CuTTYProgramFiles]cutty.exe" />
         </RegistryKey>
      </Component>
   </Package>
</Wix>
